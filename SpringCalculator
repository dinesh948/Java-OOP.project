package org.ethnotech.springcalculator.controller.Repo;

import org.ethnotech.springcalculator.AddEntity;
import org.ethnotech.springcalculator.controller.Service.AddService;
import org.springframework.beans.factory.annotation.Autowired;


import org.springframework.web.bind.annotation.GetMapping;
import org.springframework.web.bind.annotation.PostMapping;
import org.springframework.web.bind.annotation.RequestBody;

import org.springframework.web.bind.annotation.RestController;

import java.util.List;

@RestController
public class AddCon {
    @Autowired
    private AddService ser;
    @PostMapping("/add")
    public AddEntity add(@RequestBody  AddEntity en)
    {
       return ser.add(en);
    }
    @PostMapping("/sub")
    public AddEntity sub(@RequestBody AddEntity en){
        return ser.sub(en);
    }
    @PostMapping("/mul")
    public AddEntity mul(@RequestBody AddEntity en){
        return ser.mul(en);
    }
    @PostMapping("/div")
    public AddEntity div(@RequestBody AddEntity en){
        return ser.div(en);
    }
    @GetMapping("/getAll")
    public List<AddEntity> getAll()
    {
        return ser.getAll();
    }

}
